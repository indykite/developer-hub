WEATHER_PORT=6004
ADVERTISED_HOST=weather
WEATHER_AGENT_NAME=weather_agent
WEATHER_DEFAULT_CITY=London
WEATHER_TIMEOUT=15
LOG_LEVEL=INFO

# Optional: enable the CIQ-backed HQ weather path. When MCP_SERVER_URL is set
# AND the prompt mentions HQ / headquarters / office, the agent calls
# ciq_execute against the canbank get-hq-weather knowledge query instead of
# hitting Open-Meteo directly. Other cities always take the direct path.
MCP_SERVER_URL=
IK_APP_AGENT_KEY=
INDYKITE_BASE_URL=
CIQ_QUERY_HQ_WEATHER=get-hq-weather
