CHATBOT_PORT=5800
ORCHESTRATOR_HOST=localhost
ORCHESTRATOR_PORT=6001
ORCHESTRATOR_TIMEOUT=300
ID_SERVER_BASE_URL=https://idsvr.indykite.one/oauth/v2/
ID_SERVER_INTROSPECT_ENDPOINT=oauth-introspect
ID_SERVER_TOKEN_ENDPOINT=oauth-token
ID_SERVER_AUTHORIZE_ENDPOINT=oauth-authorize
ID_SERVER_CLIENT_ID=
ID_SERVER_CLIENT_SECRET=
# Token endpoint client auth: "basic" (HTTP Basic header) or "post" (form body). Default: basic.
ID_SERVER_TOKEN_AUTH=basic
ID_SERVER_SCOPES=openid profile email
# OAuth2 redirect after login (must match your chatbot URL)
CHATBOT_REDIRECT_URL=http://127.0.0.1:5800/auth/callback
# Session secret for Flask (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=
