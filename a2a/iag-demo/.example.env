# !!!!! IMPORTANT !!!!!
# make sure your Provider client is set up with the correct chatbot redirect URL
# (i.e. http://${CHATBOT_HOST}:${CHATBOT_PORT}/auth/callback)
# and that you are using the correct host in your browser
# (i.e. if the CHATBOT_HOST is localhost, don't connect to 127.0.0.1 and vice versa)

# [Required] Pick your env
INDYKITE_BASE_URL=https://api.<ENV>.indykite.com

# [Required] Setup from HUB or API required for the IAG
CIQ_QUERY_ID=ciq_query_gid_or_name
WORKFLOW_ID=wf1
APP_AGENT_CREDENTIALS_TOKEN=valid.appagent.token
CIQ_QUERY_STOCK_PRICE=get-stock-quote
CIQ_QUERY_PURCHASE_LIMIT=get-stock-trade-threshold
CIQ_QUERY_STORE_DECISION=store-decision

# [Required] MCP configuration
IK_APP_AGENT_KEY=
MCP_SERVER_URL=https://dev.mcp.indykite.com/mcp/v1/<PROJECT_GID_URL_ENCODED>

# [Required] From your IdP Provider configuration
CHATBOT_IDP_CLIENT_ID=console
CHATBOT_IDP_CLIENT_SECRET=
ORCHESTRATOR_IDP_CLIENT_ID=indykiteagent
ORCHESTRATOR_IDP_CLIENT_SECRET=
RETRIEVER_IDP_CLIENT_ID=indykiteagent-2
RETRIEVER_IDP_CLIENT_SECRET=
WEATHER_IDP_CLIENT_ID=indykiteagent-3
WEATHER_IDP_CLIENT_SECRET=


# [Optional] Setup Gemini or local LLM
# Use Gemini instead of local Ollama when true (GEMINI_ENABLED or GEMENI_ENABLED)
GEMINI_ENABLED=false
# When using Ollama from Docker, set to reach host: OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
LOCAL_LLM_MODEL=qwen3:14b-q8_0

# [Optional] Chatbot setup
# Generate a fresh secret with:
#   docker run --rm python:3.12 python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=CHANGE_ME

# [Optional] Logging
LOG_LEVEL=DEBUG

# [Ignore] Network setup (no need to change unless port conflicts)
CHATBOT_PORT=3000
CHATBOT_HOST=localhost
IAG_ORCHESTRATOR_PORT=8881
IAG_ORCHESTRATOR_HOST=orchestrator-iag
ORCHESTRATOR_PORT=6001
ORCHESTRATOR_HOST=orchestrator
IAG_RETRIEVER_PORT=8882
IAG_RETRIEVER_HOST=retriever-iag
RETRIEVER_PORT=6002
RETRIEVER_HOST=retriever
IAG_WEATHER_PORT=8884
IAG_WEATHER_HOST=weather-iag
WEATHER_PORT=6004
WEATHER_HOST=weather
