RETRIEVER_PORT=6002
RETRIEVER_AGENT_NAME=retriever_agent
LLM_MODEL=qwen3:14b-q8_0
MCP_SERVER_URL=https://us.mcp.indykite.com/mcp/v1/gid%3AAAAAApo7TvCs_0TQt-WFbP5KxMM
IK_APP_AGENT_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# Use Gemini instead of local Ollama when true (GEMINI_ENABLED or GEMENI_ENABLED)
GEMINI_ENABLED=false
# Set to DEBUG to log MCP RPC request payloads
LOG_LEVEL=INFO
# Sent as X-IndyKite-Base-URL header on MCP calls (Indykite API region)
INDYKITE_BASE_URL=https://us.api.indykite.com
# CIQ query IDs used by max_purchase_amount (stock price and purchase limit)
CIQ_QUERY_STOCK_PRICE=get-stock-price
CIQ_QUERY_PURCHASE_LIMIT=get-purchase-limit
