# IndyKite API Configuration
# Copy this file to .env and fill in your actual values

# Service Account token from https://eu.hub.indykite.com/service-accounts
SA_TOKEN=your_service_account_token_here

# API endpoint URL (use eu or us depending on your region)
URL_ENDPOINTS=https://eu.api.indykite.com
# OR
# URL_ENDPOINTS=https://us.api.indykite.com

# Organization Id
ORGANIZATION_ID=gid:....
